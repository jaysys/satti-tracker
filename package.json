{
  "name": "temp-pltr",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --env-file-if-exists=.env --watch server/index.js",
    "build": "vite build",
    "start": "NODE_ENV=production node --env-file-if-exists=.env server/index.js"
  },
  "dependencies": {
    "@blueprintjs/core": "^5.16.3",
    "@blueprintjs/icons": "^5.13.1",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "cesium": "^1.139.1",
    "concurrently": "^9.1.2",
    "satellite.js": "^6.0.2",
    "vite": "^6.1.0",
    "vite-plugin-static-copy": "^3.3.0"
  }
}
